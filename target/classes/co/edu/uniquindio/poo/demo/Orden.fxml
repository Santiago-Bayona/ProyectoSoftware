<?xml version="1.0" encoding="UTF-8"?>

<?import io.github.palexdev.materialfx.controls.MFXButton?>
<?import io.github.palexdev.materialfx.controls.MFXDatePicker?>
<?import io.github.palexdev.materialfx.controls.MFXTableView?>
<?import io.github.palexdev.materialfx.controls.MFXTextField?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="680.0" prefWidth="820.0"
            style="-fx-background-color: #F5F5F5;"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uniquindio.poo.demo.VC.OrdenVC">
    <children>
        <VBox AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0"
              spacing="16"
              style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 8, 0, 0, 2);">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <MFXButton fx:id="bttVolver" text="← Volver" onAction="#Volver"
                       style="-fx-background-color: #E0E0E0; -fx-text-fill: #424242; -fx-background-radius: 4;"/>

            <Label text="Gestión de Órdenes"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>

            <GridPane hgap="16" vgap="4">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                </columnConstraints>
                <rowConstraints><RowConstraints/></rowConstraints>

                <MFXTextField fx:id="txtID" floatingText="ID de Orden"
                              GridPane.columnIndex="0" GridPane.rowIndex="0" maxWidth="Infinity"/>
                <MFXDatePicker fx:id="dpFecha" floatingText="Fecha"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"/>
            </GridPane>

            <!-- Tablas de selección con más altura -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Seleccionar Vehículo" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                    <MFXTableView fx:id="tbVehiculo"
                                  prefHeight="200.0" minHeight="160.0"
                                  maxHeight="Infinity" VBox.vgrow="ALWAYS"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Seleccionar Mecánicos (Ctrl+Click)" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                    <MFXTableView fx:id="tbMecanico"
                                  prefHeight="200.0" minHeight="160.0"
                                  maxHeight="Infinity" VBox.vgrow="ALWAYS"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <MFXButton fx:id="bttLimpiarOrden" text="Limpiar" onAction="#LimpiarOrden"
                           style="-fx-background-color: #E0E0E0; -fx-text-fill: #424242; -fx-background-radius: 4;"/>
                <MFXButton fx:id="bttEliminarOrden" text="Eliminar" onAction="#EliminarOrden"
                           style="-fx-background-color: #EF5350; -fx-text-fill: white; -fx-background-radius: 4;"/>
                <MFXButton fx:id="bttModificarOrden" text="Modificar" onAction="#ModificarOrden"
                           style="-fx-background-color: #FB8C00; -fx-text-fill: white; -fx-background-radius: 4;"/>
                <MFXButton fx:id="bttAgregarOrden" text="Agregar" onAction="#AgregarOrden"
                           style="-fx-background-color: #1565C0; -fx-text-fill: white; -fx-background-radius: 4;"/>
            </HBox>

            <MFXTableView fx:id="tbOrden" VBox.vgrow="ALWAYS" maxHeight="Infinity" prefHeight="200.0"/>
        </VBox>
    </children>
</AnchorPane>
